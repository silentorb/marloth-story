{
  "name": "marloth-story",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": ["packages/*"],
  "scripts": {
    "watch": "bun run --cwd packages/rippledoc start",
    "build:watch": "bun run --cwd packages/rippledoc run build",
    "notion:import": "bun run --cwd packages/notion-importer start",
    "editor:dev": "bun run --cwd packages/marloth-editor dev:standalone",
    "editor:api": "bun run --cwd packages/marloth-editor dev:api",
    "editor:build": "bun run --cwd packages/marloth-editor build"
  }
}
