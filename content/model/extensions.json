{
  "version": 1,
  "extensions": [
    {
      "id": "spatial-graph",
      "enabled": true,
      "editorModule": "tome-spatial-graph/editor",
      "htmlModule": "tome-spatial-graph/html",
      "serverModule": "tome-spatial-graph/server"
    },
    {
      "id": "schema-diagram",
      "enabled": true,
      "editorModule": "tome-schema-diagram/editor",
      "htmlModule": "tome-schema-diagram/html",
      "serverModule": "tome-schema-diagram/server"
    },
    {
      "id": "tome-query",
