#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
API_PORT="${TOME_EDITOR_API_PORT:-${MARLOTH_EDITOR_API_PORT:-3847}}"
API_BASE="http://127.0.0.1:${API_PORT}"
WEBVIEW_URL="${TOME_EDITOR_WEBVIEW_URL:-${MARLOTH_EDITOR_WEBVIEW_URL:-http://127.0.0.1:5173}}"
WEBVIEW_BASE="${WEBVIEW_URL%/}"

wait_for_url() {
  local url="$1"
  local label="$2"
  for _ in $(seq 1 40); do
    if curl -sf "$url" >/dev/null 2>&1; then
      echo "${label} ready at ${url}"
      return 0
    fi
    sleep 0.25
  done
  echo "${label} failed to start within 10s" >&2
  return 1
}

start_api() {
  if curl -sf "${API_BASE}/api/health" >/dev/null 2>&1; then
    echo "Tome API already running at ${API_BASE}"
    return 0
  fi
  local log="${TOME_API_LOG:-${MARLOTH_API_LOG:-/tmp/tome-api.log}}"
  nohup bun run --cwd "$ROOT/packages/tome-editor" dev:api >>"$log" 2>&1 &
  disown 2>/dev/null || true
  wait_for_url "${API_BASE}/api/health" "Tome API" || {
    echo "See ${log}" >&2
    return 1
  }
}

start_webview() {
  if curl -sf "${WEBVIEW_BASE}/" >/dev/null 2>&1; then
    echo "Tome webview dev server already running at ${WEBVIEW_BASE}"
    return 0
  fi
  local log="${TOME_WEBVIEW_LOG:-${MARLOTH_WEBVIEW_LOG:-/tmp/tome-webview.log}}"
  nohup bun run --cwd "$ROOT/packages/tome-editor" dev:webview >>"$log" 2>&1 &
  disown 2>/dev/null || true
  wait_for_url "${WEBVIEW_BASE}/" "Tome webview dev server" || {
    echo "See ${log}" >&2
    return 1
  }
}

start_api
start_webview
