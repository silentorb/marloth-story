{
    "name": "Marloth Story",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "remoteUser": "vscode",
    "mounts": [
        "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
    ],
    "postCreateCommand": "bun install --frozen-lockfile",
    "updateContentCommand": "bun install --frozen-lockfile",
    "postAttachCommand": "bash scripts/marloth-editor-start",
    "customizations": {
        "vscode": {
            "extensions": [],
            "settings": {
                "files.eol": "\n"
            }
        }
    }
}
