{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Marloth: sync content cache",
      "type": "shell",
      "command": "bun run content:sync",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Marloth: validate content model",
      "type": "shell",
      "command": "bun run validate:content-model",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Marloth: validate workspace",
      "type": "shell",
      "command": "bun run validate:workspace",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
