{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Notion: legacy full import (--clean, destructive)",
      "type": "shell",
      "command": "bun run notion:import -- --clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Marloth Editor: build",
      "type": "shell",
      "command": "bun run editor:build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Marloth Editor: build extension",
      "type": "shell",
      "command": "bun run build:extension",
      "options": {
        "cwd": "${workspaceFolder}/packages/marloth-editor"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Marloth Editor: dev servers",
      "type": "shell",
      "command": "bash scripts/marloth-editor-start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false,
        "close": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Marloth Editor: dev (API + webview)",
      "type": "shell",
      "command": "bun run editor:dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
