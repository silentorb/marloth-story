{
  "name": "marloth-editor",
  "displayName": "Marloth Editor",
  "description": "Notion-style markdown editor for Marloth design records in the SQLite graph",
  "version": "0.1.0",
  "private": true,
  "publisher": "marloth",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "marloth.openHome",
        "title": "Marloth: Open Home",
        "icon": "$(home)"
      },
      {
        "command": "marloth.openRecord",
        "title": "Marloth: Open Record"
      }
    ],
    "customEditors": [
      {
        "viewType": "marloth.editor",
        "displayName": "Marloth Editor",
        "selector": [
          {
            "filenamePattern": "marloth://*"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "marloth.openHome"
        },
        {
          "command": "marloth.openRecord"
        }
      ]
    }
  },
  "scripts": {
    "dev": "bun run dev:standalone",
    "dev:standalone": "bun run dev:api & bun run dev:webview",
    "dev:api": "bun --watch src/api/server.ts",
    "dev:webview": "vite",
    "dev:extension": "bun run build:extension --watch",
    "build": "bun run build:webview && bun run build:extension",
    "build:webview": "vite build",
    "build:extension": "bun run scripts/build-extension.ts",
    "test": "bun test src",
    "vscode:prepublish": "bun run build"
  },
  "dependencies": {
    "@milkdown/crepe": "7.20.0",
    "marloth-db": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.23",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/vscode": "1.90.0",
    "@vitejs/plugin-react": "4.3.4",
    "esbuild": "0.25.1",
    "typescript": "5.8.2",
    "vite": "6.2.2"
  }
}
