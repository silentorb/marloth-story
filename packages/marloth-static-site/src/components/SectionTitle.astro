---
import { nodePagePath } from "../lib/markdown";

interface Props {
  title: string;
  typeNodeId?: string | null;
  base: string;
}

const { title, typeNodeId, base } = Astro.props;
---

<h2 class="marloth-record-section-title">
  {
    typeNodeId ? (
      <a class="marloth-record-section-title-link" href={nodePagePath(typeNodeId, base)}>
        {title}
      </a>
    ) : (
      title
    )
  }
</h2>
