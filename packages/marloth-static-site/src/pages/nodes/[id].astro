---
import NodeLayout from "../../layouts/NodeLayout.astro";
import { getSiteBase, loadAllNodes } from "../../lib/content";
import {
  prepareNodeMarkdown,
  renderMarkdownToHtml,
  resolvePageTitleAndContent,
} from "../../lib/markdown";

export function getStaticPaths() {
  const base = getSiteBase();
  const nodes = loadAllNodes();
  const titleById = new Map(nodes.map((node) => [node.id.toLowerCase(), node.title]));
  return nodes.map((node) => {
    const { title } = resolvePageTitleAndContent(node.body, node.title);
    const prepared = prepareNodeMarkdown(node.body, node.title, base, (id) =>
      titleById.get(id.toLowerCase()) ?? "Untitled",
    );
    return {
      params: { id: node.id },
      props: {
        title,
        markdown: prepared.markdown,
        dynamicNodeIds: [...prepared.dynamicNodeIds],
      },
    };
  });
}

interface Props {
  title: string;
  markdown: string;
  dynamicNodeIds: string[];
}

const { title, markdown, dynamicNodeIds } = Astro.props;
const bodyHtml = markdown
  ? await renderMarkdownToHtml(markdown, new Set(dynamicNodeIds))
  : "";
---

<NodeLayout title={title}>
  <h1 class="page-title">{title}</h1>
  {
    bodyHtml ? (
      <article class="prose" set:html={bodyHtml} />
    ) : (
      <p class="prose-empty">No content.</p>
    )
  }
</NodeLayout>
